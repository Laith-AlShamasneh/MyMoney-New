{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "SqlConnection": "Data Source=(localdb)\\MSSQLLocalDB;Initial Catalog=MyMoney;Integrated Security=True;Trust Server Certificate=True"
  },
  "Jwt": {
    "Issuer": "SecureAPI",
    "Audience": "SecureAPI",
    "SecretKey": "ILFXvXQkdro5W0o1qoQuLNeqhGAC/nYU2477Hb9vpJA=",
    "ExpiryHours": 12
  },
  "Storage": {
    "FolderPaths": {
      "IconsFolder": "assets/icons",
      "VideosFolder": "media/videos",
      "UserUploads": "users/uploads"
    }
  },
  "Serilog": {
    "Using": [
      "Serilog.Sinks.Console",
      "Serilog.Sinks.MSSqlServer"
    ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    },
    "Enrich": [
      "FromLogContext"
    ],
    "WriteTo": [
      {
        "Name": "Console"
      },
      {
        "Name": "MSSqlServer",
        "Args": {
          "connectionString": "Data Source=(localdb)\\MSSQLLocalDB;Initial Catalog=MyMoneyLogs;Integrated Security=True;Trust Server Certificate=True",
          "sinkOptionsSection": {
            "tableName": "B2CLogs",
            "autoCreateSqlTable": true
          },
          "columnOptionsSection": {
            "customColumns": [
              {
                "ColumnName": "UserId",
                "DataType": "bigint",
                "AllowNull": true
              },
              {
                "ColumnName": "IPAddress",
                "DataType": "nvarchar",
                "DataLength": 50,
                "AllowNull": true
              },
              {
                "ColumnName": "RequestPath",
                "DataType": "nvarchar",
                "DataLength": 2048,
                "AllowNull": true
              },
              {
                "ColumnName": "RequestMethod",
                "DataType": "nvarchar",
                "DataLength": 10,
                "AllowNull": true
              },
              {
                "ColumnName": "RequestBody",
                "DataType": "nvarchar",
                "DataLength": -1,
                "AllowNull": true
              }
            ]
          }
        }
      }
    ]
  }
}