          "sinkOptionsSection": {
            "tableName": "B2CLogs",
            "autoCreateSqlTable": true
          },
          "columnOptionsSection": {
            "customColumns": [
              {
                "ColumnName": "UserId",
                "DataType": "bigint",
                "AllowNull": true
              },
              {
                "ColumnName": "IPAddress",
                "DataType": "nvarchar",
                "DataLength": 50,
                "AllowNull": true
              },
              {
                "ColumnName": "RequestPath",
                "DataType": "nvarchar",
                "DataLength": 2048,
                "AllowNull": true
              },
              {
                "ColumnName": "RequestMethod",
                "DataType": "nvarchar",
                "DataLength": 10,
                "AllowNull": true
              },
              {
                "ColumnName": "RequestBody",
                "DataType": "nvarchar",
                "DataLength": -1,
                "AllowNull": true
              }
            ]
          }
        }
      }
    ]
  }
